# ============================================================
# AFAMAR - Archivo de ejemplo de variables de entorno
# Copiar este archivo a .env y completar los valores
# ============================================================

# -----------------------------------------------------------
# Entorno
# -----------------------------------------------------------
ENVIRONMENT=development  # development | production | testing
APP_NAME=AFAMAR
APP_VERSION=1.1.0
DEBUG=true               # true para logs detallados en desarrollo

# -----------------------------------------------------------
# ENVIRONMENT=development 
# Base de datos (SQLite para desarrollo, MySQL para producción)
# Ejemplo SQLite: sqlite:///./afamar.db
# Ejemplo MySQL:  mysql+pymysql://user:pass@host:3306/dbname
# -----------------------------------------------------------

# Si usas MySQL (ENVIRONMENT=production)
DB_HOST=mysql-central
DB_PORT=3306
DB_NAME=afamar
DB_USER=afamar
DB_PASSWORD=

# -----------------------------------------------------------
# Seguridad (generar en producción con: openssl rand -hex 32)
# -----------------------------------------------------------
SECRET_KEY=tu-secret-key-super-seguro-cambiar-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=18

# -----------------------------------------------------------
# API y CORS
# -----------------------------------------------------------
API_URL=/api/v1
API_PORT=3095
CORS_ALLOW_ORIGINS=http://localhost:3090,http://localhost:5173,http://localhost:80

# -----------------------------------------------------------
# Frontend
# -----------------------------------------------------------
FRONTEND_URL=http://localhost:3090
WEB_PORT=3090

# -----------------------------------------------------------
# Email (SMTP) - Configurar para envío de PDFs
# -----------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD=tu-clave-de-aplicacion
SMTP_FROM=tu-correo@gmail.com

# -----------------------------------------------------------
# WhatsApp API (opcional, para notificaciones)
# -----------------------------------------------------------
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# -----------------------------------------------------------
# Logging
# -----------------------------------------------------------
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
